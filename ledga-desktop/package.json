{
    "name": "ledga-desktop-app",
    "productName": "Ledga",
    "description": "Ledga Finance AI-Assistant",
    "main": "dist/main/index.js",
    "type": "module",
    "scripts": {
        "predev": "electron-rebuild -f -w better-sqlite3",
        "dev": "electron-vite dev --watch",
        "build": "npm run generate:licenses && tsc && electron-vite build && electron-builder --config electron-builder.json --publish never",
        "postinstall": "electron-builder install-app-deps",
        "lint": "eslint . --ext .ts,.tsx,.js",
        "pretest": "npm rebuild better-sqlite3",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "update:cookie-filters": "node scripts/update-cookie-filters.cjs",
        "analyze:i18n": "node scripts/validate-translations.cjs",
        "fix:i18n": "node scripts/flatten-translations.cjs",
        "fix:lint": "eslint . --ext .ts,.tsx,.js --fix",
        "generate:licenses": "node scripts/generate-licenses.mjs"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "engines": {
        "node": "24.11.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Ledga-Finance-App/ledga-desktop-app.git"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.88",
        "@tanstack/react-router": "^1.170.16",
        "ai": "^6.0.62",
        "better-sqlite3": "^12.11.1",
        "csv-parse": "^5.6.0",
        "electron-store": "^11.0.2",
        "i18next": "^26.3.1",
        "mailparser": "^3.9.12",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-i18next": "^17.0.8",
        "uuid": "^14.0.1",
        "zod": "^4.4.3"
    },
    "debug": {
        "env": {
            "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
        }
    },
    "devDependencies": {
        "@electron/notarize": "^3.0.1",
        "@eslint/js": "^9.22.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.17",
        "@tanstack/react-router-devtools": "^1.120.18",
        "@tanstack/router-plugin": "^1.120.18",
        "@types/better-sqlite3": "^7.6.13",
        "@types/glob": "^8.1.0",
        "@types/mailparser": "^3.4.6",
        "@types/mime-types": "^3.0.1",
        "@types/node": "^24.7.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@types/semver": "^7.7.1",
        "@vitejs/plugin-react-swc": "^3.8.0",
        "electron": "39.8.5",
        "electron-builder": "^26.6.0",
        "electron-vite": "^4.0.0",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-better-tailwindcss": "^4.5.0",
        "eslint-plugin-i18next": "^6.1.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-unicorn": "^60.0.0",
        "glob": "^11.1.0",
        "globals": "^16.0.0",
        "knip": "^5.64.2",
        "license-checker-evergreen": "^6.2.1",
        "rollup-plugin-visualizer": "^6.0.4",
        "supabase": "^2.78.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.26.1",
        "vite": "^6.4.2",
        "vitest": "^3.2.6"
    }
}
